# Copy this file to `.env` and fill in your real key.
# Get one at: https://console.anthropic.com/ → API Keys → Create Key
ANTHROPIC_API_KEY=sk-ant-your-key-here

# Optional: override the model. Defaults to claude-sonnet-4-6.
# Options: claude-opus-4-6 (best quality, ~5x cost)
#          claude-sonnet-4-6 (recommended — balanced)
#          claude-haiku-4-5-20251001 (fastest/cheapest, lower prose quality)
# ENRICH_MODEL=claude-sonnet-4-6
